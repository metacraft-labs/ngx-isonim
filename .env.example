# Override flake inputs with local checkouts. The most common combo for
# IsoNim/faststreams development:
#
# NIX_FLAKE_OVERRIDE_INPUTS='nim-faststreams=path:../nim-faststreams isonim=path:../isonim nim-everywhere=path:../nim-everywhere'
#
# For local isonim core development:
# Ensure ../isonim is on Nim path via nim.cfg or nimble path
