#!/usr/bin/env bash

source_url \
  "https://raw.githubusercontent.com/nix-community/nix-direnv/3.0.4/direnvrc" \
  "sha256-DzlYZ33mWF/Gs8DDeyjr8mnVmQGx7ASYqA5WlxwvBG4="

# Load direnv-nix-flake-overrides plugin for local flake input overrides
# See .env.example for configuration options
# flake-overrides plugin: prefer a sibling checkout (workspace dev — always
# current), else the pinned published copy (CI / standalone clones).
if [[ -f ../direnv-nix-flake-overrides/plugin/flake-overrides.bash ]]; then
	watch_file ../direnv-nix-flake-overrides/plugin/flake-overrides.bash
	source ../direnv-nix-flake-overrides/plugin/flake-overrides.bash
else
	source_url "https://direnv-flake-overrides.blocksense.network/plugin" \
		"sha256-BTxlsheP/7/FQw9IBPGFc6zYTl5S2qdAAt3EUqfkbjI="
fi

dotenv_if_exists
watch_file .env

# Use flake with optional local overrides from .env

# Full-auto: override every flake input that has a same-named sibling checkout
# next to this repo (honouring the metacraft `-src` suffix convention).
export NIX_FLAKE_OVERRIDE_AUTO=1
export NIX_FLAKE_OVERRIDE_AUTO_STRIP_SUFFIXES=-src
eval "use flake . $(flake_override_args_quoted)"
